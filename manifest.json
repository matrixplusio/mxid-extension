{
  "manifest_version": 3,
  "name": "MXID Form-Fill",
  "version": "0.1.0",
  "description": "Auto-submits login forms for MXID form-fill (SWA) apps using credentials vaulted in MXID.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "http://localhost:3500/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "MXID Form-Fill"
  },
  "options_page": "src/options.html"
}
